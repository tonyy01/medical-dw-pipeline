# ============================================================
# 医疗数据仓库 ETL Pipeline — 环境配置
# 复制本文件为 .env 并修改
# cp .env.example .env
# ============================================================

# PostgreSQL 连接配置
PGHOST=localhost
PGPORT=5432
PGDATABASE=medical_dw
PGUSER=postgres
PGPASSWORD=postgres

# ETL 配置
SYNTHEA_CSV_DIR=./synthea/output/csv
ETL_BATCH_SIZE=10000

# Airflow 配置（仅 Docker 部署时需要）
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__FERNET_KEY=
